APP_ENV=development
API_ADDR=:8080
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s
READINESS_TIMEOUT=750ms
BOOTSTRAP_API_KEYS=tenant-dev-a|Development Tenant A|dev-key-tenant-a,tenant-dev-b|Development Tenant B|dev-key-tenant-b
OBJECT_STORAGE_DIR=/tmp/workflow-objects
TENANT_EXECUTE_LIMIT=20
TENANT_EXECUTE_WINDOW=1m
OTEL_EXPORTER=stdout
OTEL_SAMPLE_RATIO=1.0

POSTGRES_ADDR=localhost:5432
REDIS_ADDR=localhost:6379
MINIO_ADDR=localhost:9000

POSTGRES_DSN=postgres://workflow:workflow@localhost:5432/workflow?sslmode=disable
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workflow
